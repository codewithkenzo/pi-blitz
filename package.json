{
  "name": "@codewithkenzo/pi-blitz",
  "version": "0.1.0-alpha.10",
  "description": "Pi extension for Blitz: fast, token-efficient code edits using the Zig Blitz CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "extensions": [
    "./dist/index.js"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf ./dist && bun build ./index.ts --outfile ./dist/index.js --target node && mkdir -p ./dist/skills && cp -R ./skills/pi-blitz ./dist/skills/pi-blitz",
    "tsc": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "pi",
    "pi-agent",
    "pi-coding-agent",
    "pi-agent-core",
    "ast",
    "tree-sitter",
    "fast-edit",
    "blitz"
  ],
  "dependencies": {
    "@codewithkenzo/blitz": "0.1.0-alpha.10",
    "@sinclair/typebox": "^0.34.0",
    "effect": "4.0.0-beta.48"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.63.1",
    "@mariozechner/pi-tui": "*",
    "@types/bun": "1.3.12",
    "bun-types": "1.3.12",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-agent-core": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@mariozechner/pi-tui": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@codewithkenzo/blitz-darwin-arm64": "0.1.0-alpha.10",
    "@codewithkenzo/blitz-darwin-x64": "0.1.0-alpha.10",
    "@codewithkenzo/blitz-linux-x64-musl": "0.1.0-alpha.10",
    "@codewithkenzo/blitz-linux-arm64-musl": "0.1.0-alpha.10",
    "@codewithkenzo/blitz-windows-x64": "0.1.0-alpha.10"
  },
  "license": "MIT"
}
